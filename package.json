{
  "name": "niceeval-eval",
  "version": "1.0.0",
  "description": "niceeval 的文档效果评估仓库：用 niceeval 评估正在使用 niceeval 的 coding agent",
  "private": true,
  "type": "module",
  "scripts": {
    "export:debug-fixture": "tsx scripts/export-debug-fixture.ts",
    "typecheck": "tsx scripts/typecheck.ts",
    "install-eval": "niceeval exp install",
    "debug-eval": "niceeval exp debug",
    "show": "niceeval show",
    "view": "niceeval view",
    "pin:candidate": "tsx scripts/pin-candidate.ts"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.12.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "e2b": "^2.35.0",
    "niceeval": "^0.9.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "yaml": "^2.9.0"
  }
}
